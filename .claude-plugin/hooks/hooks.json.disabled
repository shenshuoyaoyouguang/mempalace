{
  "description": "MemPalace auto-save and pre-compact hooks",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace-hook --hook stop --harness claude-code",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mempalace-hook --hook precompact --harness claude-code",
            "timeout": 90
          }
        ]
      }
    ]
  }
}
